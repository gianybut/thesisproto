# Backend Configuration Example
# Copy this to .env and update values as needed

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=pothole-detection-secret-key-2026
DEBUG=True

# Database
SQLALCHEMY_DATABASE_URI=sqlite:///pothole_detection.db

# File Upload
MAX_CONTENT_LENGTH=524288000  # 500MB in bytes
UPLOAD_FOLDER=uploads
PROCESSED_FOLDER=processed
SNAPSHOTS_FOLDER=snapshots

# Model Path
MODEL_PATH=../ml/models/best.pt

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Server
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
